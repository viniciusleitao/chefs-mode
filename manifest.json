{
  "manifest_version": 3,
  "name": "Chef's Mode",
  "description": "Strip bloated recipe pages down to just ingredients, steps, and a main image in a high-contrast, large-type cooking view.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Chef's Mode"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
